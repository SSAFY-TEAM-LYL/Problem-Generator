# IPE 환경 변수 템플릿. 사용 시 `.env`로 복사하고 값을 채울 것.
# `.env`는 .gitignore되어 commit되지 않음.

# Required: Anthropic API 키
ANTHROPIC_API_KEY=sk-ant-...

# Sandbox tier 자동 선택 (auto | docker | sandboxexec | rlimit)
IPE_SANDBOX=auto

# 비용 가드 (단일 problem 생성에 허용되는 최대 USD)
IPE_MAX_COST_USD=5.0

# Optional: LangSmith trace export (1로 설정 시 활성)
IPE_LANGSMITH=

# Optional: OpenTelemetry collector endpoint
IPE_OTEL_ENDPOINT=

# ---- API 서버 (ipe.v2.api — B2C 계약 v1.0) ----

# Required(API 서버 기동 시): 백엔드↔파이프라인 정적 인증 키 (X-API-Key 헤더)
IPE_API_KEY=

# 동시 생성 슬롯 (초과 요청은 429+Retry-After; 기본 2)
IPE_MAX_CONCURRENT_GENERATIONS=2
